# Configurações do Banco MySQL (para produção)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_mysql_aqui
DB_NAME=vagaexpress

# Chave secreta para JWT (IMPORTANTE: mude para algo seguro!)
JWT_SECRET=sua_chave_secreta_jwt_muito_segura_aqui_123456789

# Configurações de Email (Gmail - opcional para desenvolvimento)
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=sua_senha_app_gmail
EMAIL_DEV_MODE=true

# Porta do servidor
PORT=3000

# Controle de limpeza de usuários/reservas
# use true apenas em desenvolvimento ou em ambiente seguro
ALLOW_CLEAR_USERS=false